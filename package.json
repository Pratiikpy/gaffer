    "e2e:parlay": "ts-node src/parlay-e2e.ts",
    "keeper": "ts-node src/keeper.ts",
    "capture": "ts-node src/capture.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.95.3",
    "@solana/spl-token": "^0.4.9",
    "axios": "^1.7.7",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
